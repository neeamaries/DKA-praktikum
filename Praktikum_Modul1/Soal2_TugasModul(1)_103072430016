def Fibonacci(n): # Fungsi fibonacci
    a = 0 # Mendeklarasikan angka pertama 
    b = 1 # Mendeklarasikan angka kedua 
    
    for i in range(n): # Melakukan perulangan sesuai input user 
        a, b = b, a + b # Mengganti a menjadi b  
                        # Mengganti b menjadi a + b untuk setiap perulangan
    
    return a # Mengembalikan nilai fibonacci ke n 

def cetak(n): # Fungsi mencetak fibonacci
    for i in range(n): # Melakukan perulangan sesuai input user 
        print(Fibonacci(i)) # Mencetak nilai a sesuai tiap perulangan


n = int(input("Masukkan nilai n: ")) # Menerima input dari user 
cetak(n) # Memasukkannya ke fungsi cetak
